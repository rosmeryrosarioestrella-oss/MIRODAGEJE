# --- Opción A: Autenticación integrada de Windows (recomendado en su PC) ---
# El proceso de Node usa su usuario de Windows; en SQL Server debe existir ese login (o un grupo) con acceso a la base.
# Instancia con nombre (ej. SQLEXPRESS): use doble barra en el host, ej. localhost\\SQLEXPRESS:49152
DATABASE_URL="sqlserver://localhost:1433;database=mirodageje;integratedSecurity=true;encrypt=true;trustServerCertificate=true"

# --- Opción B: SQL Server Authentication (usuario/contraseña) ---
# DATABASE_URL="sqlserver://localhost:1433;database=mirodageje;user=sa;password=SuClave;encrypt=true;trustServerCertificate=true"

# --- Opción C: Docker (compose en la raíz) — suele usar SQL auth, no Windows ---
# DATABASE_URL="sqlserver://localhost:1433;database=mirodageje;user=sa;password=Mirodageje_Db_2026!;encrypt=true;trustServerCertificate=true"

JWT_SECRET="cambia-esto-en-produccion-minimo-32-caracteres"
PORT=4000
